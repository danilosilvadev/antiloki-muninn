# ─── antiloki-muninn · environment template ────────────────────────────────
# Two consumers:
#   [fn]  = Supabase Edge Function secret → set with: supabase secrets set KEY=value
#   [api] = muninn api → copy the [api] lines into api/.env (gitignored)
#
# Signup list, in dependency order:
#   1. Registrar         — canonical domain + 2 secondary sending domains   (slice 0)
#   2. Supabase          — https://supabase.com   free tier                 (slice 0)
#   3. PostHog           — https://posthog.com    free tier                 (slice 0)
#   4. Google Workspace  — 2-3 inboxes per secondary domain                 (slice 0)
#   5. Smartlead         — https://smartlead.ai   from $39/mo (warmup)      (slice 0)
#   6. Telegram          — @BotFather → bot token, $0                       (slice 1)
#   7. OpenRouter        — https://openrouter.ai  ~$5-20/mo at 300 leads    (slice 1)
#   8. FullEnrich        — https://fullenrich.com from $29/mo (500 credits) (slice 1)
#   9. Apollo            — https://apollo.io      $49+/mo                   (slice 2)
#  10. Resend            — https://resend.com     consented mail ONLY       (slice 4)
#  11. Calendly          — booking link for positive replies

# ── Supabase (slice 0) ──────────────────────────────────────────────────────
SUPABASE_PROJECT_REF=                # e.g. abcdefghijklmnopqrst (from the project URL)

# ── Edge function secrets (slice 0) ────────────────────────────────────────
MUNINN_EDGE_SECRET=                  # [fn] HMAC secret for unsub tokens + ip hashing (openssl rand -hex 32)
ALLOWED_ORIGINS=                     # [fn] comma list, e.g. https://yourdomain.tld
LANDING_URL=                         # [fn] https://yourdomain.tld (referral redirect target)
RATE_LIMIT_PER_HOUR=20               # [fn] waitlist joins per ip per hour

# ── Analytics (slice 0) ─────────────────────────────────────────────────────
POSTHOG_KEY=                         # phc_... (baked into site/ by scripts/configure-site.mjs)
POSTHOG_HOST=https://us.i.posthog.com

# ── muninn api (slice 1) — these lines live in api/.env ────────────────────
PORT=41945                           # [api] loopback only; the console (slice 2) expects 41945
SUPABASE_DB_URL=                     # [api] SESSION-pooler URI: dashboard → Connect → Session pooler
                                     #       (pg-boss + drizzle share it; prepare=false is handled)
OPENROUTER_API_KEY=                  # [api] analysis + drafting
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
MUNINN_ANALYSIS_MODEL=anthropic/claude-sonnet-4.5   # [api] any capable OpenRouter slug — swap freely
FULLENRICH_API_KEY=                  # [api] enrichment (URL → profile + verified work email)
FULLENRICH_BASE_URL=https://app.fullenrich.com/api/v1
FULLENRICH_USD_PER_CREDIT=0.058      # [api] cost-ledger conversion (starter tier: $29/500 credits)
TELEGRAM_BOT_TOKEN=                  # [api] from @BotFather (/newbot)
TELEGRAM_OPERATOR_CHAT_ID=           # [api] leave empty on first boot — the bot tells you your id
MUNINN_FIT_THRESHOLD=70              # [api] fit_score gate: below → parked, no dossier ping
MUNINN_DIGEST_CRON=0 12 * * *        # [api] daily digest, UTC (12:00 UTC ≈ 09:00 BRT)

# ── Slice 2+ (leave empty until those slices land) ──────────────────────────
APOLLO_API_KEY=                      # [api] find-similar expansion (slice 2)
SMARTLEAD_API_KEY=                   # [api] sequences (slice 3)
RESEND_API_KEY=                      # [api] consented mail only (slice 4)
