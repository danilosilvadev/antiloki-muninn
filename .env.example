# ─── antiloki-muninn · environment template ────────────────────────────────
# Copy to .env (gitignored). Two consumers:
#   [fn]  = Supabase Edge Function secret → set with:
#           supabase secrets set KEY=value
#   [api] = muninn api .env on the operator machine (arrives slice 1)
#
# Signup list, in dependency order (slice 0 needs the first three blocks):
#   1. Registrar         — canonical domain + 2 secondary sending domains
#   2. Supabase          — https://supabase.com  (free tier fine for slice 0)
#   3. PostHog           — https://posthog.com   (free tier)
#   4. Google Workspace  — 2-3 inboxes per secondary domain
#   5. Smartlead         — https://smartlead.ai  (warmup + campaigns, from $39/mo)
#   6. OpenRouter        — https://openrouter.ai (slice 1)
#   7. FullEnrich        — https://fullenrich.com (slice 1, from $29/mo)
#   8. Apollo            — https://apollo.io     (slice 2)
#   9. Resend            — https://resend.com    (slice 4, consented mail ONLY)
#  10. Calendly          — booking link for positive replies

# ── Supabase (slice 0) ──────────────────────────────────────────────────────
SUPABASE_PROJECT_REF=                # e.g. abcdefghijklmnop (from the project URL)
SUPABASE_URL=                        # [api] https://<ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=           # [api] service_role key — NEVER ships to a browser bundle
SUPABASE_DB_URL=                     # [api] session-pooler URL (pg-boss needs LISTEN/NOTIFY)

# ── Edge function secrets (slice 0) ────────────────────────────────────────
MUNINN_EDGE_SECRET=                  # [fn] HMAC secret for unsub tokens + ip hashing (openssl rand -hex 32)
ALLOWED_ORIGINS=                     # [fn] comma list, e.g. https://yourdomain.tld,http://localhost:8788
LANDING_URL=                         # [fn] https://yourdomain.tld (referral redirect target)
RATE_LIMIT_PER_HOUR=20               # [fn] waitlist joins per ip per hour

# ── Analytics (slice 0) ─────────────────────────────────────────────────────
POSTHOG_KEY=                         # phc_... (baked into site/ by scripts/configure-site.mjs)
POSTHOG_HOST=https://us.i.posthog.com

# ── Slice 1+ (leave empty until those slices land) ──────────────────────────
OPENROUTER_API_KEY=                  # [api] analysis + drafting
FULLENRICH_API_KEY=                  # [api] enrichment waterfall
TELEGRAM_BOT_TOKEN=                  # [api] operator console v0
APOLLO_API_KEY=                      # [api] find-similar expansion (slice 2)
SMARTLEAD_API_KEY=                   # [api] sequences (slice 3)
RESEND_API_KEY=                      # [api] consented mail only (slice 4)
